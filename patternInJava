/*
PATTERN 8 

          *  
        * *
      * * *
    * * * *
  * * * * *
  

*/

      public static void pattern8(int n){
        for(int i = 0 ; i < n;i++){
            System.out.println(" ");
            for(int k = 0 ; k <n-i;k++){
                System.out.print( "  ");
            }
            for(int j = 0 ; j <i+1;j++){
                System.out.print("* ");
            }
        }
    }

/*

PATTERN 9 
 
  * * * * *  
    * * * *
      * * *
        * *
          *

*/






         public static void pattern9(int n){
        for(int i = 0 ; i < n;i++){
            System.out.println(" ");
               for(int k = 0 ; k <1+i;k++){
                System.out.print( "  ");
            }
             for(int j = n ; j >i;j--){
                System.out.print("* ");
            }
         
           
        }
   }




   /*  
   PATTERN 10
   
    
                              *  
                            * * *
                          * * * * *
                        * * * * * * *
                      * * * * * * * * *
                        
   
   
   
   */


      public static void pattern10(int n){
        for(int i = 0 ; i < n/2;i++){
            System.out.println(" ");

             for(int m = 0 ; m < n;m++){
                System.out.print( "  ");
             }
               for(int k = 0 ; k < n/2 -i;k++){
                System.out.print( "  ");
            }
             for(int j = 0 ; j <i+1;j++){
                System.out.print("* ");
            }
             for(int b = 0 ; b <i;b++){
                System.out.print("* ");
            }
        }
           
        }
   


    public static void main(String[] args) {
        pattern9(5);
