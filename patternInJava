/*PATTERN 0)


*  *  *  *  *   
*  *  *  *  *
*  *  *  *  *
*  *  *  *  *
*  *  *  *  *



*/

 public static void pattern0(int n){
        for(int i = 0 ; i < n;i++){
            System.out.println(" ");
            for(int j = 0 ; j <n;j++){
                System.out.print("*  ");
            }
        }
    }





