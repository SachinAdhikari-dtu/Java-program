// code to print all possibility of head and tail when n times coin is tossed 
public static void t(String ans , int s , int s2, int e , int e2){
  if(s==e&&s2==e2){
    System.out.println(ans);
    return;
  }

  if(e>s){
    t(ans +"H", s+1, s2, e, e2);
  }
  if(e2> s2){
    t(ans+"V", s, s2+1, e, e2);
  }
  return ;
}


