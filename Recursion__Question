// merge sort
public static int[] mergeSort(int arr[]){
  int m= arr.length/2;

  if(arr.length==1){
    return arr;
  }
int l[]= Arrays.copyOfRange(arr, 0, m);
int r[]=Arrays.copyOfRange(arr, m, arr.length);
  l = mergeSort(l);
        r = mergeSort(r);

  return merge(l,r);
}


// merger function of merge sort


public static int[] merge(int l[] , int r[] ){
int arr[]= new int[l.length+r.length];
int s=0;
int sr=0;
int e= l.length;
int er=r.length;
int k=0 ;
while(s< e && sr < er){
if(l[s] > r[sr]){
  arr[k++]=r[sr++];
}else{
  arr[k++]=l[s++];
}
}
while(s< e ){

  arr[k++]=l[s++];

}
while(sr < er){

  arr[k++]=r[sr++];

}
 return arr;

}
    

 // merge sort in place 
 public static void mergeinPlace(int arr[], int s , int e){
  if(e-s==1){
    return ;
  }
  int m = (s+e)/2;
  mergeinPlace(arr,s,m);
  mergeinPlace(arr,m,e);
  mergerInplace(arr,s,m,e);
 }

//  merger in place 
public static void mergerInplace(int arr[] , int s , int m , int e){
  int ans[]= new int[e-s];
  int i= s;
   int j = m;
   int k= 0;
   while(i<m&&j<e){
    if(arr[i] > arr[j]){
      ans[k++]=arr[j++];
    }else{
      ans[k++]=arr[i++];
    }
   }

   while(j<e){
      ans[k++]=arr[j++];
   
   }

   while(i<m){
   
      ans[k++]=arr[i++];
    
   }
   for(i=0;i< e-s;i++){
    arr[s+i]=ans[i];
   }
   return ;

}



public static void quicksort(int arr[], int l, int h) {
    if (l >= h) return; // base case

    int s = l;
    int e = h;
    int m = s + (e - s) / 2;
    int p = arr[m]; // pivot

    while (s <= e) {
        while (arr[s] < p) {
            s++;
        }
        while (arr[e] > p) {
            e--;
        }
        if (s <= e) {
            int t = arr[s];
            arr[s] = arr[e];
            arr[e] = t;
            s++;
            e--;
        }
    }

    // recursive calls after partitioning
    quicksort(arr, l, e);
    quicksort(arr, s, h);
}



