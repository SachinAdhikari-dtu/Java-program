// formation of parenthesis
public static void help(String ans, int o, int c, ArrayList<String> l) {
    if (o == 0 && c == 0) {
        l.add(ans); // store instead of printing
        return;
    }

    // If we still have open brackets, we can place one
    if (o > 0) {
        help(ans + "(", o - 1, c, l);
    }

    // We can place a closing bracket only if there are more closing left than opening
    if (c > o) {
        help(ans + ")", o, c - 1, l);
    }
}


